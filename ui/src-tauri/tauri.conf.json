{
  "$schema": "https://raw.githubusercontent.com/nicegoodthings/tauri-v2-schema/refs/heads/main/tauri.conf.json",
  "productName": "RsClaw",
  "version": "2026.4.26",
  "identifier": "ai.rsclaw.app",
  "build": {
    "beforeBuildCommand": "yarn export",
    "beforeDevCommand": "yarn export:dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOWNLOAD/rsclaw/**",
          "$DOWNLOAD/rsclaw/**/*",
          "$HOME/.rsclaw/**",
          "$HOME/.rsclaw/**/*"
        ]
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "width": 1000,
        "height": 720,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "title": "RsClaw",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "2026, RsClaw Contributors. All Rights Reserved.",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "externalBin": ["binaries/rsclaw"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "RsClaw AI Agent Engine - manage intelligent agents, model routing, and multi-channel messaging.",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": "K87X8CQ78Y",
      "signingIdentity": "Developer ID Application: Hua Lan (K87X8CQ78Y)"
    },
    "resources": [
      "icons/icon.png",
      "icons/icon-tray.png",
      "icons/icon-tray@2x.png",
      "resources/bge-small-zh/*"
    ],
    "shortDescription": "RsClaw AI Agent Engine",
    "targets": ["deb", "rpm", "appimage", "app", "dmg", "nsis"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "languages": ["English", "SimpChinese", "TradChinese", "Japanese", "Korean", "French", "German", "Spanish", "Russian", "Thai"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
